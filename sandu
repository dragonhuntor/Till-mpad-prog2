# monthly_payment.py

def calculate_monthly_payment(principal: float, annual_rate: float, years: int) -> float:
    """
    Beräknar den månatliga betalningen för ett lån.

    Args:
        principal (float): Lånebelopp i kronor, t.ex. 2000.0
        annual_rate (float): Årsränta i procent, t.ex. 6.0 för 6 %
        years (int): Löptid i år, t.ex. 10

    Returns:
        float: Månatlig betalning i kronor
    """
    monthly_rate = annual_rate / 100 / 12
    periods = years * 12

    
    if monthly_rate == 0:
        return principal / periods

   
    numerator = principal * monthly_rate
    denominator = 1 - (1 + monthly_rate) ** (-periods)
    monthly_payment = numerator / denominator
    return monthly_payment



if __name__ == "__main__":
    principal = float(input("Lånebelopp: "))
    annual_rate = float(input("Årsränta (%): "))
    years = int(input("Löptid (år): "))
    payment = calculate_monthly_payment(principal, annual_rate, years)
    print(f"Din månatliga betalning är: {payment:.2f} kr")
